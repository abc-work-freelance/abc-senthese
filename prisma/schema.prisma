// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  INSTRUMENTISTE
}

enum ProthesisType {
  HIP
  KNEE
  SHOULDER
}

enum PaymentMode {
  CASH
  VIREMENT
  CHEQUE
  CAHIER_DE_CHARGE
}

enum CommandStatus {
  VALIDEE
  AFFECTEE
  REPORTEE
  ANNULEE
  COMPLETEE
}

enum Permission {
  COMMAND_CREATE
  COMMAND_UPDATE
  COMMAND_DELETE
  COMMAND_STATUS_UPDATE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
}

// --------------------------------------
// Models
// --------------------------------------

model User {
  id          Int          @id @default(autoincrement())
  name        String
  familyName  String
  role        UserRole
  // Validate email ends with @abc-synthese.com in application logic/Zod
  email       String       @unique
  password    String

  // Phone number in international format (e.g. +212600000000) — used for WhatsApp notifications
  phone       String?

  // Fine-grained permissions for admins
  permissions Permission[] @default([])

  // Account approval gate. New accounts must be approved by the super admin
  // (matching EMAILADMIN env var) before they can access dashboard data.
  approved    Boolean      @default(false)

  // Relations
  createdCommands  Command[] @relation("CreatedByAdmin")
  assignedCommands Command[] @relation("AssignedToInstrumentiste")
  resetTokens      PasswordResetToken[]

  @@map("users")
}

// Short-lived one-time codes for the "forgot password" flow. The 6-digit code
// is never stored in plaintext — only its bcrypt hash. Tokens are single-use
// and expire quickly; brute-force is bounded by the attempts counter.
model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model Command {
  id               Int              @id @default(autoincrement())
  reference        String           @unique
  type             ProthesisType
  dateIntervention DateTime
  dateLivraison    DateTime
  lienIntervention String?
  ville            String
  address          String?
  clinique         String?
  doctorName       String?
  modePaiement     PaymentMode
  status           CommandStatus    @default(VALIDEE)
  commentaire      String?

  // File Handling
  completionReport String?          // URL/Path to file
  attachments      Attachment[]

  // Relations: Users
  instrumentisteId Int?
  instrumentiste   User?            @relation("AssignedToInstrumentiste", fields: [instrumentisteId], references: [id])
  
  createdById      Int
  createdBy        User             @relation("CreatedByAdmin", fields: [createdById], references: [id])

  // Relation: Products via Join Table (to track Quantity)
  commandProducts  CommandProduct[]

  // Timestamps
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("commands")
}

model Product {
  id              Int              @id @default(autoincrement())
  code            String           @unique
  name            String
  
  // Relation: Commands via Join Table
  commandProducts CommandProduct[]

  @@map("products")
}

// The Join Table for Explicit Many-to-Many
model CommandProduct {
  commandId Int
  command   Command @relation(fields: [commandId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  quantity  Int     @default(1)

  // Composite ID ensures a product appears only once per command
  @@id([commandId, productId])
  @@map("command_products")
}

model Attachment {
  id        String   @id @default(uuid())
  url       String   // Path or URL to the file
  name      String?  // Original filename
  createdAt DateTime @default(now())

  // Relation to Command
  commandId Int
  command   Command  @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}